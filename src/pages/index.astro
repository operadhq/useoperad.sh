    border-collapse: collapse;
    font-size: 0.88rem;
  }

  th, td {
    padding: 0.85rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  tr:last-child td {
    border-bottom: none;
  }

  th {
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-faint);
    background: var(--bg-alt);
  }

  tr {
    transition: background 0.15s ease;
  }

  tbody tr:hover {
    background: rgba(0, 0, 0, 0.01);
  }

  .highlight-col {
    background: rgba(59, 91, 219, 0.03);
    font-weight: 600;
  }

  th.highlight-col {
    color: var(--accent);
    background: rgba(59, 91, 219, 0.06);
  }

  /* ─── INSPIRATIONS ─────────────────── */
  .inspirations {
    padding: 6rem 0;
  }

  .inspirations h2 {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .insp-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .insp-card {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    box-shadow: var(--card-shadow);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out), border-color 0.3s ease;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .insp-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--card-shadow-hover);
    border-color: rgba(59, 91, 219, 0.2);
    text-decoration: none;
    color: inherit;
  }

  .insp-tag {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
  }

  .insp-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0.5rem 0 0.25rem;
    color: var(--text);
  }

  .insp-paper-id {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }

  .insp-card p:last-child {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* ─── STEP-THROUGH DEMO ──────────────── */
  .step-demo {
    padding: 6rem 0;
  }

  .step-demo h2 {
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .demo-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .demo-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .step-btn {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: inherit;
    font-size: 0.82rem;
    text-align: left;
    width: 100%;
  }

  .step-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    opacity: 0.4;
    margin-top: 2px;
    flex-shrink: 0;
  }

  .step-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .step-label {
    font-weight: 600;
    font-size: 0.8rem;
  }

  .step-desc {
    font-size: 0.68rem;
    opacity: 0.5;
    line-height: 1.4;
  }

  .step-btn:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
  }

  .step-btn.active {
    background: rgba(59, 91, 219, 0.1);
    border-color: rgba(59, 91, 219, 0.25);
    color: var(--text);
  }

  .step-btn.active .step-num {
    color: var(--accent);
    opacity: 1;
  }

  .step-btn.active .step-desc {
    opacity: 0.7;
  }

  .step-btn.completed {
    color: var(--text);
  }

  .step-btn.completed .step-num {
    color: #16a766;
    opacity: 1;
  }

  .play-btn {
    margin-top: 0.5rem;
    padding: 0.6rem 1rem;
    border: 1px solid rgba(59, 91, 219, 0.3);
    border-radius: 8px;
    background: rgba(59, 91, 219, 0.08);
    color: var(--accent);
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    transition: all 0.25s ease;
    width: 100%;
  }

  .play-btn:hover {
    background: rgba(59, 91, 219, 0.15);
    border-color: rgba(59, 91, 219, 0.5);
  }

  .play-btn.playing {
    background: rgba(251, 76, 47, 0.1);
    border-color: rgba(251, 76, 47, 0.3);
    color: #fb4c2f;
  }

  .demo-canvas {
    background: #0F1019;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255, 255, 255, 0.03) inset;
  }

  #demo-svg {
    width: 100%;
    height: auto;
    display: block;
    padding: 8px;
  }

  .demo-edge {
    stroke: rgba(255, 255, 255, 0.08);
    stroke-width: 1.5;
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    opacity: 0;
    transition: stroke-dashoffset 0.8s ease, opacity 0.4s ease;
  }

  .demo-edge.visible {
    stroke-dashoffset: 0;
    opacity: 1;
    stroke: rgba(255, 255, 255, 0.18);
  }

  .demo-node {
    opacity: 0;
    transform-origin: center;
    transition: opacity 0.4s ease;
  }

  .demo-node.visible {
    opacity: 1;
    animation: nodeAppear 0.5s var(--ease-spring) both;
  }

  @keyframes nodeAppear {
    0%   { transform: scale(0); }
    70%  { transform: scale(1.08); }
    100% { transform: scale(1); }
  }

  .node-input    { fill: rgba(59, 91, 219, 0.15); stroke: #3B5BDB; stroke-width: 1.5; }
  .node-created  { fill: rgba(22, 167, 102, 0.10); stroke: #16a766; stroke-width: 1.5; }
  .node-risk     { fill: rgba(251, 76, 47, 0.12);  stroke: #fb4c2f; stroke-width: 1.5; }
  .node-decision { fill: rgba(255, 173, 71, 0.08); stroke: #ffad47; stroke-width: 1.5; }

  .node-text {
    fill: rgba(255, 255, 255, 0.9);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    font-weight: 600;
  }

  .node-subtext {
    fill: rgba(255, 255, 255, 0.35);
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    font-weight: 400;
  }

  .demo-code-panel {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .demo-code-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .demo-code-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
  }

  .demo-code-dot:nth-child(1) { background: #FF5F57; opacity: 0.7; }
  .demo-code-dot:nth-child(2) { background: #FEBC2E; opacity: 0.7; }
  .demo-code-dot:nth-child(3) { background: #28C840; opacity: 0.7; }

  .demo-code-filename {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.25);
    margin-left: 6px;
  }

  .demo-code-body {
    margin: 0;
    padding: 0.75rem 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.7);
    overflow-x: auto;
    background: transparent;
    min-height: 80px;
  }

  .demo-code-panel :global(.ck) { color: #BB9AF7; }
  .demo-code-panel :global(.cs) { color: #9ECE6A; }
  .demo-code-panel :global(.cn) { color: #FF9E64; }
  .demo-code-panel :global(.cc) { color: #565F89; }
  .demo-code-panel :global(.ct) { color: rgba(255,255,255,0.5); }

  .event-log {
    padding: 0.6rem 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    max-height: 100px;
    overflow-y: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
  }

  .log-label {
    display: block;
    font-weight: 700;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.2);
    margin-bottom: 0.15rem;
  }

  .event-log :global(.log-entry) {
    display: block;
  }

  .event-log :global(.log-ts)    { color: rgba(255, 255, 255, 0.2); }
  .event-log :global(.log-event) { color: #BB9AF7; }
  .event-log :global(.log-arrow) { color: rgba(255, 255, 255, 0.15); }
  .event-log :global(.log-target) { color: #9ECE6A; }

  /* ─── SECTION DIVIDERS (gradient fade) ── */
  .ai-assistants,
  .more-than-memory,
  .where-it-fits,
  .capabilities,
  .worked-examples,
  .step-demo,
  .babyagi-example,
  .comparison,
  .inspirations {
    position: relative;
  }

  .ai-assistants::before,
  .more-than-memory::before,
  .where-it-fits::before,
  .capabilities::before,
  .worked-examples::before,
  .step-demo::before,
  .babyagi-example::before,
  .comparison::before,
  .inspirations::before {
    content: '';
    position: absolute;
    top: 0;
    left: -2rem;
    right: -2rem;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--border-strong) 20%, var(--border-strong) 80%, transparent 100%);
  }

  /* ─── RESPONSIVE ───────────────────── */
  @media (max-width: 768px) {
    .hero-grid,
    .ai-grid,
    .fits-grid,
    .babyagi-grid,
    .demo-grid,
    .example-block {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .demo-sidebar {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .step-btn {
      flex: 0 0 auto;
      width: auto;
      padding: 0.45rem 0.65rem;
      font-size: 0.72rem;
    }

    .play-btn {
      width: auto;
      flex: 0 0 auto;
    }

    .example-block.reverse .example-code {
      order: 0;
    }

    .hero {
      padding: 3.5rem 0 3rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-sub {
      font-size: 1rem;
    }

    .layer-cards,
    .cap-grid {
      grid-template-columns: 1fr;
    }

    .insp-grid {
      grid-template-columns: 1fr 1fr;
    }

    .ai-assistants,
    .more-than-memory,
    .where-it-fits,
    .capabilities,
    .worked-examples,
    .step-demo,
    .babyagi-example,
    .comparison,
    .inspirations {
      padding: 3.5rem 0;
    }

    table {
      font-size: 0.78rem;
    }

    th, td {
      padding: 0.6rem 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .insp-grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 1.7rem;
    }
  }
</style>

<script>
  const STEP_CODE = [
    { file: 'seed.ts', code:
`<span class="ck">const</span> graph = <span class="ck">await</span> runtime.createGraph(<span class="cs">'claim-4521'</span>)

<span class="cc">// Seed the graph with initial objects</span>
<span class="ck">await</span> graph.addObject({
  type: <span class="cs">'claim'</span>,
  data: { id: <span class="cs">'CLM-4521'</span>, status: <span class="cs">'open'</span> }
})
<span class="ck">await</span> graph.addObject({
  type: <span class="cs">'policy'</span>,
  data: { id: <span class="cs">'HO-3-12345'</span>, type: <span class="cs">'HO-3'</span> }
})` },
    { file: 'claim-intake.ts', code:
`<span class="ck">const</span> intake = behavior({
  name: <span class="cs">'claim-intake'</span>,
  on: [<span class="cs">'object.created'</span>],
  where: { <span class="cs">'payload.objectType'</span>: <span class="cs">'claim'</span> },
  handler: <span class="ck">async</span> (event, graph) => {
    <span class="ck">const</span> claimant = <span class="ck">await</span> graph.addObject({
      type: <span class="cs">'claimant'</span>,
      data: { name: <span class="cs">'John Doe'</span>, phone: <span class="cs">'555-0142'</span> }
    })
  }
})` },
    { file: 'evidence-extract.ts', code:
`<span class="ck">const</span> extract = behavior({
  name: <span class="cs">'evidence-extract'</span>,
  on: [<span class="cs">'object.created'</span>],
  where: { <span class="cs">'payload.objectType'</span>: <span class="cs">'claimant'</span> },
  handler: <span class="ck">async</span> (event, graph) => {
    <span class="ck">await</span> graph.addObject({ type: <span class="cs">'evidence'</span>,
      data: { kind: <span class="cs">'photo'</span>, desc: <span class="cs">'roof damage'</span> } })
    <span class="ck">await</span> graph.addObject({ type: <span class="cs">'evidence'</span>,
      data: { kind: <span class="cs">'report'</span>, filed: <span class="cs">'2024-03-12'</span> } })
  }
})` },
    { file: 'contradiction-check.ts', code:
`<span class="ck">const</span> check = behavior({
  name: <span class="cs">'contradiction-check'</span>,
  on: [<span class="cs">'object.created'</span>],
  where: { <span class="cs">'payload.objectType'</span>: <span class="cs">'evidence'</span> },
  handler: <span class="ck">async</span> (event, graph) => {
    <span class="ck">const</span> gap = detectTimelineGap(event.payload)
    <span class="ck">if</span> (gap) <span class="ck">await</span> graph.addObject({
      type: <span class="cs">'risk_flag'</span>,
      data: { reason: <span class="cs">'timeline_mismatch'</span>, severity: <span class="cs">'high'</span> }
    })
  }
})` },
    { file: 'risk-scoring.ts', code:
`<span class="ck">const</span> scoring = behavior({
  name: <span class="cs">'risk-scoring'</span>,
  on: [<span class="cs">'object.created'</span>],
  where: { <span class="cs">'payload.objectType'</span>: <span class="cs">'risk_flag'</span> },
  handler: <span class="ck">async</span> (event, graph) => {
    <span class="ck">await</span> graph.recordDecision({
      selectedAction: <span class="cs">'approve'</span>,
      confidence: <span class="cn">0.72</span>,
      alternatives: [
        { action: <span class="cs">'deny'</span>, score: <span class="cn">0.28</span> },
        { action: <span class="cs">'escalate'</span>, score: <span class="cn">0.15</span> }
      ]
    })
  }
})` },
    { file: 'carrier-routing.ts', code:
`<span class="ck">const</span> routing = behavior({
  name: <span class="cs">'carrier-routing'</span>,
  on: [<span class="cs">'decision.recorded'</span>],
  handler: <span class="ck">async</span> (event, graph) => {
    <span class="ck">const</span> match = <span class="ck">await</span> findCarrier(event.payload)
    <span class="ck">await</span> graph.addObject({
      type: <span class="cs">'carrier_resp'</span>,
      data: { carrier: <span class="cs">'Acme Ins.'</span>, match: <span class="cs">'coverage'</span> }
    })
  }
})` },
    { file: 'approval-gate.ts', code:
`<span class="ck">const</span> gate = behavior({
  name: <span class="cs">'approval-gate'</span>,
  on: [<span class="cs">'object.created'</span>],
  where: { <span class="cs">'payload.objectType'</span>: <span class="cs">'carrier_resp'</span> },
  handler: <span class="ck">async</span> (event, graph, ctx) => {
    <span class="cc">// Governance: AI suggests, human decides</span>
    <span class="ck">await</span> ctx.requestApproval({
      reviewer: <span class="cs">'claims-team'</span>,
      confidence: <span class="cn">0.72</span>,
      reason: <span class="cs">'risk_flag present'</span>
    })
  }
})` },
  ]

  const STEPS = [
    {
      nodes: ['policy', 'claim'],
      edges: [],
      events: [
        { ts: '00:00.000', event: 'graph.created',   target: 'claim-4521' },
        { ts: '00:00.012', event: 'object.created',   target: 'claim  { id: "CLM-4521", status: "open" }' },
        { ts: '00:00.014', event: 'object.created',   target: 'policy { id: "HO-3-12345", type: "HO-3" }' },
      ],
    },
    {
      nodes: ['claimant'],
      edges: ['policy-claim', 'claim-claimant'],
      events: [
        { ts: '00:00.031', event: 'behavior.fired',   target: 'claim-intake  on: object.created(claim)' },
        { ts: '00:00.048', event: 'object.created',   target: 'claimant { name: "John Doe", phone: "555-0142" }' },
        { ts: '00:00.049', event: 'edge.created',      target: 'claim → claimant  (extracted_from)' },
      ],
    },
    {
      nodes: ['evidence-1', 'evidence-2'],
      edges: ['claim-ev1', 'claim-ev2'],
      events: [
        { ts: '00:00.062', event: 'behavior.fired',   target: 'evidence-extract  on: object.created(claimant)' },
        { ts: '00:00.084', event: 'object.created',   target: 'evidence-1 { type: "photo", desc: "roof damage" }' },
        { ts: '00:00.085', event: 'object.created',   target: 'evidence-2 { type: "report", filed: "2024-03-12" }' },
        { ts: '00:00.086', event: 'edge.created',      target: 'claim → evidence-1, claim → evidence-2' },
      ],
    },
    {
      nodes: ['risk-flag'],
      edges: ['ev1-risk'],
      events: [
        { ts: '00:00.102', event: 'behavior.fired',   target: 'contradiction-check  on: object.created(evidence)' },
        { ts: '00:00.118', event: 'object.created',   target: 'risk_flag { reason: "timeline_mismatch", severity: "high" }' },
        { ts: '00:00.119', event: 'edge.created',      target: 'evidence-1 → risk_flag  (flagged_by)' },
      ],
    },
    {
      nodes: ['assessment'],
      edges: ['ev1-assessment', 'risk-assessment'],
      events: [
        { ts: '00:00.131', event: 'behavior.fired',   target: 'risk-scoring  on: object.created(risk_flag)' },
        { ts: '00:00.155', event: 'decision.recorded', target: 'assessment { score: 0.72, band: "medium" }' },
        { ts: '00:00.156', event: 'decision.meta',     target: 'alternatives: [deny (0.28), escalate (0.15)]' },
        { ts: '00:00.157', event: 'edge.created',      target: 'evidence-1 → assessment, risk_flag → assessment' },
      ],
    },
    {
      nodes: ['carrier-resp'],
      edges: ['assessment-carrier'],
      events: [
        { ts: '00:00.170', event: 'behavior.fired',   target: 'carrier-routing  on: decision.recorded(assessment)' },
        { ts: '00:00.188', event: 'object.created',   target: 'carrier_resp { carrier: "Acme Ins.", match: "coverage" }' },
        { ts: '00:00.189', event: 'edge.created',      target: 'assessment → carrier_resp  (routed_to)' },
      ],
    },
    {
      nodes: ['approval'],
      edges: ['carrier-approval'],
      events: [
        { ts: '00:00.201', event: 'behavior.fired',   target: 'approval-gate  on: object.created(carrier_resp)' },
        { ts: '00:00.215', event: 'governance.pending',target: 'approval { status: "pending-review", conf: 0.72 }' },
        { ts: '00:00.216', event: 'governance.notify', target: 'reviewer: "claims-team"  reason: "risk_flag present"' },
      ],
    },
  ]

  let currentStep = -1
  let playInterval: ReturnType<typeof setInterval> | null = null
  let allLogEntries: Array<{ts: string, event: string, target: string}> = []

  function advanceToStep(targetStep: number) {
    currentStep = targetStep

    // Update step buttons
    document.querySelectorAll('.step-btn').forEach((btn, i) => {
      btn.classList.remove('active', 'completed')
      if (i < targetStep) btn.classList.add('completed')
      else if (i === targetStep) btn.classList.add('active')
    })

    // Reset all nodes and edges
    document.querySelectorAll('.demo-node').forEach(n => n.classList.remove('visible'))
    document.querySelectorAll('.demo-edge').forEach(e => e.classList.remove('visible'))

    // Reveal nodes and edges for all steps up to targetStep
    for (let s = 0; s <= targetStep; s++) {
      const step = STEPS[s]
      step.nodes.forEach(id => {
        document.querySelector(`.demo-node[data-node="${id}"]`)?.classList.add('visible')
      })
      step.edges.forEach(id => {
        document.querySelector(`.demo-edge[data-edge="${id}"]`)?.classList.add('visible')
      })
    }

    // Update code panel
    const codeStep = STEP_CODE[targetStep]
    document.getElementById('demo-code-filename')!.textContent = codeStep.file
    document.getElementById('demo-code-body')!.innerHTML = codeStep.code

    // Build cumulative event log
    allLogEntries = []
    for (let s = 0; s <= targetStep; s++) {
      allLogEntries.push(...STEPS[s].events)
    }

    const log = document.getElementById('event-log')!
    const entries = log.querySelectorAll('.log-entry')
    entries.forEach(e => e.remove())

    allLogEntries.forEach(ev => {
      const span = document.createElement('span')
      span.className = 'log-entry'
      span.innerHTML = `<span class="log-ts">${ev.ts}</span> <span class="log-event">${ev.event}</span> <span class="log-arrow">→</span> <span class="log-target">${ev.target}</span>`
      log.appendChild(span)
    })

    log.scrollTop = log.scrollHeight
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.step-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const step = parseInt((btn as HTMLElement).dataset.step!, 10)
        if (playInterval) stopPlay()
        advanceToStep(step)
      })
    })

    const playBtn = document.getElementById('play-all')!
    playBtn.addEventListener('click', () => {
      if (playInterval) {
        stopPlay()
        return
      }
      playBtn.textContent = '■ Stop'
      playBtn.classList.add('playing')
      let step = 0
      advanceToStep(step)
      playInterval = setInterval(() => {
        step++
        if (step >= STEPS.length) {
          stopPlay()
          return
        }
        advanceToStep(step)
      }, 1400)
    })

    function stopPlay() {
      if (playInterval) clearInterval(playInterval)
      playInterval = null
      playBtn.textContent = '▶ Play all'
      playBtn.classList.remove('playing')
    }

    advanceToStep(0)
  })
</script>
